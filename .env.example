# ============================================
# Dilling E-Commerce — Environment Variables
# Copy to .env.local and fill in your keys
# ============================================

# ---- Database ----
DATABASE_URL=postgresql://dilling:dilling_dev_2026@localhost:5432/dilling

# ---- Meilisearch ----
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=dilling_search_key_2026

# ---- OpenAI ----
# Required for AI chat agent
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---- Clerk Authentication ----
# Get keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- Stripe Payments ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_PAYMENT_MODE=demo

# ---- PayPal Payments ----
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=

# ---- Exchange Rates ----
EXCHANGE_RATE_API_KEY=

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:4000
